{
  "name": "feishu-bot-social",
  "version": "1.0.0",
  "description": "群聊 Bot 社交感知：上下文注入 / Bot@Bot 接收 / @alias 格式转换 / 防风暴",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.0"
    }
  },
  "activation": {
    "onStartup": true
  },
  "id": "feishu-bot-social",
  "configSchema": {
    "type": "object",
    "properties": {
      "contextGroups": { "type": "array" },
      "contextMessageCount": { "type": "number" },
      "contextCacheTtlMs": { "type": "number" },
      "stormThreshold": { "type": "number" },
      "circuitBreakerMaxOutbound": { "type": "number" },
      "circuitBreakerSilenceMs": { "type": "number" },
      "alertReceiverOpenId": { "type": "string", "description": "管理员 open_id；防风暴触发时通过 DM 通知此人。未配置则跳过 DM。" },
      "botOverrides": { "type": "object" },
      "debugLog": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
